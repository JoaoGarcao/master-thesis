import org.verifx.practical.crdts.CvRDT
import org.verifx.practical.crdts.CvRDTProof

class UWMap(
    added: Map[String, Map[String, Int]] = new Map[String, Map[String, Int]](),
    removed: Map[String, Map[String, Int]] = new Map[String, Map[String, Int]]()
) extends CvRDT[UWMap] {

    // Obter os elementos de um mapa
    def getElements(targetMap: Map[String, Map[String, Int]], key: String): Map[String, Int] = {
        if (targetMap.contains(key)) targetMap.get(key)
        else new Map[String, Int]()
    }

    def update(key: String, value: Int, id: String): UWMap = {
        val oldAdded = this.getElements(this.added, key)
        val addedPair = oldAdded.add(id, value)
        
        val oldRemoved = this.getElements(this.removed, key)
        val newRemovedForKey = oldRemoved.combine(oldAdded, (v1: Int, v2: Int) => v1)

        new UWMap(
            this.added.add(key, addedPair),
            this.removed.add(key, newRemovedForKey)
        )
    }

    def remove(key: String): UWMap = {
        val oldAdded = this.getElements(this.added, key)
        val oldRemoved = this.getElements(this.removed, key)
        
        val newRemovedForKey = oldRemoved.combine(oldAdded, (v1: Int, v2: Int) => v1)

        new UWMap(
            this.added,
            this.removed.add(key, newRemovedForKey)
        )
    }

    def merge(that: UWMap): UWMap = {
        // Quando há ids iguais escolhe-se o valor de um dos mapas
        val mergedAdded = this.added.combine(that.added, (m1: Map[String, Int], m2: Map[String, Int]) => {
            m1.combine(m2, (v1: Int, v2: Int) => v1)
        })

        val mergeRemoved = this.removed.combine(that.removed, (m1: Map[String, Int], m2: Map[String, Int]) => {
            m1.combine(m2, (v1: Int, v2: Int) => v1)
        })
        
        new UWMap(mergedAdded, mergeRemoved)
    }

    def lookup(key: String): Boolean = {
        val addedForKey = this.getElements(this.added, key)
        val removedForKey = this.getElements(this.removed, key)
        
        exists(id: String) { addedForKey.contains(id) && !removedForKey.contains(id) }
    }

    def compare(that: UWMap): Boolean = {
        forall(k: String) {
            forall(id: String) {
                (!this.getElements(this.added, k).contains(id) || this.getElements(that.added, k).contains(id)) &&
                (!this.getElements(this.removed, k).contains(id) || this.getElements(that.removed, k).contains(id))
            }
        }
    }
}

object UWMap extends CvRDTProof[UWMap]